{
  "name": "csv-custom-pro",
  "displayName": "CSV_CUSTOM_PRO",
  "publisher": "csv-custom-pro",
  "description": "无缝显示和编辑CSV文件，支持过滤/排序/搜索",
  "icon": "images-图片/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonaraphael/csv.git"
  },
  "version": "1.3.3",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=14"
  },
  "categories": [
    "Data Science",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:csv",
    "onLanguage:tsv",
    "onCommand:csv.toggleExtension",
    "onCommand:csv.toggleSerialIndex",
    "onCommand:csv.changeSeparator",
    "onCommand:csv.resetSeparator",
    "onCommand:csv.changeFontFamily",
    "onCommand:csv.changeIgnoreRows",
    "onCommand:csv.changeEncoding",
    "onCommand:csv.toggleClickableLinks",
    "onCommand:csv.toggleRowHeightMode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "csv",
        "extensions": [
          ".csv",
          ".psv"
        ],
        "aliases": [
          "CSV",
          "csv",
          "PSV",
          "psv"
        ],
        "configuration": "./config-配置/language-语言配置.json"
      },
      {
        "id": "tsv",
        "extensions": [
          ".tsv",
          ".tab"
        ],
        "aliases": [
          "TSV",
          "tsv",
          "TAB",
          "tab"
        ],
        "configuration": "./config-配置/language-语言配置.json"
      }
    ],
    "commands": [
      {
        "command": "csv.toggleExtension",
        "title": "CSV_CUSTOM_PRO: 开关扩展"
      },
      {
        "command": "csv.toggleSerialIndex",
        "title": "CSV_CUSTOM_PRO: 切换序号列"
      },
      {
        "command": "csv.changeSeparator",
        "title": "CSV_CUSTOM_PRO: 更改分隔符"
      },
      {
        "command": "csv.resetSeparator",
        "title": "CSV_CUSTOM_PRO: 重置分隔符（继承）"
      },
      {
        "command": "csv.changeFontFamily",
        "title": "CSV_CUSTOM_PRO: 更改字体"
      },
      {
        "command": "csv.changeIgnoreRows",
        "title": "CSV_CUSTOM_PRO: 隐藏前N行"
      },
      {
        "command": "csv.changeEncoding",
        "title": "CSV_CUSTOM_PRO: 更改文件编码"
      },
      {
        "command": "csv.toggleClickableLinks",
        "title": "CSV_CUSTOM_PRO: 切换可点击链接"
      },
      {
        "command": "csv.toggleRowHeightMode",
        "title": "CSV_CUSTOM_PRO: 切换行高模式（紧凑/自然折行）"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "CSV_CUSTOM_PRO 配置",
      "properties": {
        "csv.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用/禁用CSV自定义编辑器。"
        },
        "csv.fontFamily": {
          "type": "string",
          "default": "",
          "description": "CSV编辑器使用的字体。留空则继承'editor.fontFamily'。",
          "scope": "application"
        },
        "csv.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "CSV编辑器字体大小（像素）。设为0则继承'editor.fontSize'。",
          "scope": "application"
        },
        "csv.mouseWheelZoom": {
          "type": "boolean",
          "default": true,
          "description": "启用Ctrl/Cmd+鼠标滚轮缩放。",
          "scope": "application"
        },
        "csv.mouseWheelZoomInvert": {
          "type": "boolean",
          "default": false,
          "description": "反转Ctrl/Cmd+鼠标滚轮缩放方向。",
          "scope": "application"
        },
        "csv.cellPadding": {
          "type": "number",
          "default": 4,
          "description": "表格单元格垂直内边距（像素）。"
        },
        "csv.columnColorMode": {
          "type": "string",
          "enum": [
            "type",
            "theme"
          ],
          "default": "type",
          "description": "列文字颜色模式。'type'按数据类型着色，'theme'使用主题前景色。"
        },
        "csv.columnColorPalette": {
          "type": "string",
          "enum": [
            "default",
            "cool",
            "warm"
          ],
          "default": "default",
          "description": "类型着色调色板。'default'默认，'cool'偏蓝绿，'warm'偏橙红。"
        },
        "csv.diffUseThemeForeground": {
          "type": "boolean",
          "default": true,
          "description": "差异对比视图中使用主题前景色，使差异高亮可见。"
        },
        "csv.clickableLinks": {
          "type": "boolean",
          "default": true,
          "description": "单元格中的URL可点击。Ctrl/Cmd+点击打开链接。"
        },
        "csv.showTrailingEmptyRow": {
          "type": "boolean",
          "default": true,
          "description": "表格末尾显示空行，便于追加编辑。"
        },
        "csv.separatorMode": {
          "type": "string",
          "enum": [
            "extension",
            "auto",
            "default"
          ],
          "default": "extension",
          "description": "分隔符选择方式。'extension'按扩展名映射，'auto'自动检测，'default'使用默认分隔符。"
        },
        "csv.defaultSeparator": {
          "type": "string",
          "default": ",",
          "description": "默认分隔符。在JSON设置中用'\\t'表示制表符。"
        },
        "csv.separatorByExtension": {
          "type": "object",
          "default": {
            ".csv": ",",
            ".tsv": "\t",
            ".tab": "\t",
            ".psv": "|"
          },
          "additionalProperties": {
            "type": "string"
          },
          "description": "按文件扩展名映射分隔符。键为'.ext'或'ext'，值为分隔符。"
        },
        "csv.maxFileSizeMB": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "打开文件大小上限（MB）。0禁用限制。超限时提示取消、继续或禁用。"
        },
        "csv.rowHeightMode": {
          "type": "string",
          "enum": [
            "compact",
            "firstline",
            "wrap"
          ],
          "default": "firstline",
          "description": "行高模式：'compact' 紧凑（\\n当空格、横向截断）；'firstline' 单行折行（默认，保留原文、只露第一行）；'wrap' 自然折行（全展开）。可随时拖动行边界手动调整。"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "csv.editor",
        "displayName": "CSV_CUSTOM_PRO",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.tab"
          },
          {
            "filenamePattern": "*.psv"
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:bump": "python3 scripts/bump-version-版本号递增.py",
    "package:bump": "python3 scripts/bump-version-版本号递增.py --package",
    "vscode:prepublish": "npm run compile",
    "lint": "eslint 'src-源码/**/*.ts'",
    "package": "node scripts/package-vsix-with-timestamp-打包带时间戳.cjs",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "test:webview": "npm run compile && node --test out/test/webview-*.test.js"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "undici": "^6.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/papaparse": "^5.3.16",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vscode/vsce": "^2.15.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.2",
    "typescript": "^4.4.3",
    "vscode": "^1.1.37"
  }
}
